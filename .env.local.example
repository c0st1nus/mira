# =============================================================================
# Mira Growth Hack — переменные окружения
# Скопируйте файл в .env.local и заполните реальными значениями.
# .env.local в Git не попадает (см. .gitignore).
# =============================================================================

# -----------------------------------------------------------------------------
# Google Sheets (приём регистраций)
# -----------------------------------------------------------------------------
# Регистрационная форма пишет ответы в Google-таблицу через сервисный аккаунт.
# Чтобы получить значения ниже, нужно один раз настроить проект в Google Cloud
# и поделиться таблицей с сервисным аккаунтом.
#
# Шаги:
#   1. Откройте https://console.cloud.google.com и создайте проект (или выберите
#      существующий).
#   2. APIs & Services → Library → найдите "Google Sheets API" → Enable.
#   3. IAM & Admin → Service Accounts → Create service account.
#      Заполните имя, нажмите Create and continue, роль можно пропустить, Done.
#   4. Кликните по созданному сервисному аккаунту → вкладка Keys → Add key →
#      Create new key → JSON. Скачается JSON-файл с ключом.
#   5. В JSON-файле:
#        - "client_email"  → GOOGLE_SERVICE_ACCOUNT_EMAIL
#        - "private_key"   → GOOGLE_PRIVATE_KEY (целиком, вместе с переносами;
#                            переносы строк должны остаться как \n — см. ниже)
#   6. Откройте Google-таблицу, в которую пишем регистрации. Нажмите Share и
#      выдайте сервисному аккаунту (client_email) права Editor.
#   7. Из URL таблицы возьмите ID:
#        https://docs.google.com/spreadsheets/d/<ЭТО_GOOGLE_SHEET_ID>/edit
#   8. GOOGLE_SHEET_RANGE — диапазон в формате `<Лист>!A:V`. По умолчанию
#      используется "Registrations!A:V". Если листа с таким названием в
#      таблице нет, код создаст его сам и проставит заголовки колонок при
#      первой отправке формы.

# Email сервисного аккаунта (поле client_email из JSON).
# Пример: mira-hack-bot@my-project-123456.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_EMAIL=

# Приватный ключ сервисного аккаунта (поле private_key из JSON).
# ВАЖНО: значение должно быть в одну строку, переносы заменяем на \n.
# Пример: GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEv...\n-----END PRIVATE KEY-----\n"
GOOGLE_PRIVATE_KEY=

# ID таблицы (часть URL между /d/ и /edit).
GOOGLE_SHEET_ID=

# Диапазон с названием листа. Опционально — если не задано, используется
# "Registrations!A:V". Лист создаётся автоматически при первой отправке формы.
GOOGLE_SHEET_RANGE=Registrations!A:V
